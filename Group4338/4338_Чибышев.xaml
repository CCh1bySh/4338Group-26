<Window x:Class="Group4338._4338_Чибышев"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чибышев Павел - Вариант 10 (Импорт JSON / Экспорт Word)" 
        Height="550" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Лабораторная работа №4: Работа с JSON и Word (Вариант 10)" 
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Панель с кнопками (старые + новые) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <!-- Старые кнопки из ЛР3 -->
            <Button x:Name="btnImport" 
                    Content="📥 Импорт Excel" 
                    Width="120" Height="35" 
                    Margin="3" 
                    Click="btnImport_Click"
                    Background="#4CAF50" Foreground="White"
                    ToolTip="Импорт данных из Excel файла"/>

            <Button x:Name="btnExport" 
                    Content="📤 Экспорт Excel" 
                    Width="120" Height="35" 
                    Margin="3" 
                    Click="btnExport_Click"
                    Background="#2196F3" Foreground="White"
                    ToolTip="Экспорт данных в Excel с группировкой по ролям"/>

            <!-- Новые кнопки для ЛР4 -->
            <Button x:Name="btnImportJson" 
                    Content="📦 Импорт JSON" 
                    Width="120" Height="35" 
                    Margin="3" 
                    Click="btnImportJson_Click"
                    Background="#9C27B0" Foreground="White"
                    ToolTip="Импорт данных из JSON файла (5.json)"/>

            <Button x:Name="btnExportWord" 
                    Content="📄 Экспорт в Word" 
                    Width="120" Height="35" 
                    Margin="3" 
                    Click="btnExportWord_Click"
                    Background="#FF5722" Foreground="White"
                    ToolTip="Экспорт данных в Word с группировкой по ролям"/>

            <Button x:Name="btnClear" 
                    Content="🧹 Очистить" 
                    Width="80" Height="35" 
                    Margin="3" 
                    Click="btnClear_Click"
                    Background="#F44336" Foreground="White"
                    ToolTip="Очистить данные"/>
        </StackPanel>

        <!-- Таблица для отображения данных -->
        <DataGrid Grid.Row="2" 
                  x:Name="dgEmployees" 
                  AutoGenerateColumns="True" 
                  Margin="0,0,0,10"
                  AlternatingRowBackground="#F5F5F5"
                  BorderBrush="Gray" BorderThickness="1"
                  IsReadOnly="True"/>

        <!-- Статус и информация -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
            <TextBlock x:Name="txtStatus" 
                       Text="Готов к работе" 
                       FontStyle="Italic"
                       Foreground="Gray"
                       Margin="0,0,20,0"/>
            <TextBlock x:Name="txtRecordCount" 
                       Text="Записей: 0" 
                       FontWeight="Bold"
                       Foreground="#2196F3"/>
        </StackPanel>
    </Grid>
</Window>