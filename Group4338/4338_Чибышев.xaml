<Window x:Class="Group4338._4338_Чибышев"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чибышев Павел - Вариант 10" 
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnImport" Content="Импорт данных" Width="120" Height="30" Margin="5" Click="btnImport_Click"/>
            <Button x:Name="btnExport" Content="Экспорт в Excel" Width="120" Height="30" Margin="5" Click="btnExport_Click"/>
        </StackPanel>

        <!-- Таблица для отображения данных -->
        <DataGrid Grid.Row="1" x:Name="dgEmployees" AutoGenerateColumns="True" Margin="0,0,0,10"/>

        <!-- Статус -->
        <TextBlock Grid.Row="2" x:Name="txtStatus" Text="Готов к работе" HorizontalAlignment="Center"/>
    </Grid>
</Window>